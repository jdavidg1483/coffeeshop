---
import { Picture } from 'astro:assets'
import type { Post } from '@/types'

import PostMeta from './PostMeta.astro'
import PostCategories from './PostCategories.astro'

interface Props {
    post: Post
}

const { post } = Astro.props

// Estrategia de respaldo (Fallback) para la imagen destacada
const imageTarget = post.featured_images?.medium_large || post.featured_images?.medium || post.featured_images?.full;
const categories = post.category_details || [];
---

<article class="grid grid-cols-1 lg:grid-cols-3 gap-5 py-10 border-b last-of-type:border-0 border-zinc-300 items-center">
  
  {/* Bloque de Textos (Ocupa 2 columnas en pantallas grandes) */}
  <div class="lg:col-span-2 space-y-4">
    
    {/* 1. Enlace dinámico al Post */}
    <h3 class="text-coffee-900 font-black text-4xl uppercase hover:text-coffee-700 transition-colors">
        <a href={`/blog/${post.slug}`}>
            {post.title.rendered}
        </a>
    </h3>

    {/* 2. CORREGIDO: Cierre automático limpio para el componente de Meta/Fecha */}
    <PostMeta date={post.date} /> 

    {/* 3. Mapeo limpio usando tu componente modular de Categorías */}
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => <PostCategories name={cat.name} slug={cat.slug} />)}
      </div>
    )}
    
    {/* Resumen del Contenido */}
    <div set:html={post.content.rendered} class="line-clamp-2 text-zinc-600 leading-relaxed"></div>
  </div>

  {/* Bloque de Imagen Destacada (Ocupa 1 columna) */}
  <div class="w-full">
    {imageTarget?.url ? (
      <Picture 
        src={imageTarget.url}
        alt={`Imagen del Post: ${post.title.rendered}`}
        width={imageTarget.width}
        height={imageTarget.height}
        formats={['avif', 'webp']}
        class="w-full h-64 object-cover rounded-2xl shadow-sm"
      />
    ) : (
      <div class="bg-zinc-100 rounded-2xl w-full h-64 flex items-center justify-center text-zinc-400 text-sm border border-zinc-200">
        Sin imagen destacada
      </div>
    )}
  </div>

</article>