---
import { Image } from 'astro:assets'
import Logo from '@/assets/logo.svg'
import MainNav from './MainNav.astro' // 👈 ¡Corregido! Importamos tu navegación

interface Props {
    subtitle: string 
    bgImage: string
}

const {  subtitle, bgImage } = Astro.props
---

<header class="relative min-h-72 bg-cover bg-center text-white pb-12">

    
    
    <!-- Capa de fondo con la imagen dinámica -->
    <div 
        class="absolute inset-0 bg-cover bg-center -z-10" 
        style={`background-image: url('${bgImage}');`}
    ></div>

    <!-- 👈 ¡Corregido! bg-black/60 para la opacidad correcta -->
   <div class="absolute inset-0 bg-black/60"></div>

    <!-- Barra de Navegación Superior -->
    <div class="relative max-w-7xl mx-auto py-3">
        <div class="flex flex-col items-center lg:flex-row lg:justify-between">
            <a href="/">
          <!-- 👈 ¡Corregido! Forma nativa de renderizar el SVG optimizado en Astro -->
        <Image src={Logo} alt="Logo Cafetería CoffeeShop" class="w-48" />
        
        </a>
        <MainNav />
    </div>

    <h1 class="text-4xl font-black text-white text-center mt-6">{subtitle}</h1>
    </div>
    
   
   
</header>