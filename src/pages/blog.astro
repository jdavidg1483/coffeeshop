---
import BlogPosts from "@/components/ui/blog/blogPosts.astro";
import Layout from "../layouts/Layout.astro";

// 1. CORREGIDO: Agregamos &_embed al final para traer los datos de la imagen destacada
// Y usamos PUBLIC_API_URL para que no te dé undefined
const url = `${import.meta.env.API_URL}/pages?slug=blog&_embed`;
const res = await fetch(url);
const pages = await res.json();
const page = pages[0];

if (!page) {
  throw new Error("No se encontró la página 'proceso'");
}

// 2. Extracción limpia de la imagen destacada (¡Ahora sí funcionará porque viene incrustada!)
const featuredMedia = page._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = featuredMedia?.source_url || featuredMedia?.guid?.rendered || null;
const imageAlt = featuredMedia?.alt_text || page.title.rendered;

// 3. Extracción segura de ACF
const subtitulo = page.acf?.subtitle || "Bienvenidos a nuestra cafetería"; 
---

<Layout 
  title={page.title.rendered}
  subtitle={subtitulo}
  bgImage={imageUrl} 
>
    
    <div class="text-xl space-y-3 mt-10 lg:mt-0" set:html={page.content.rendered}></div>
  
    <BlogPosts />
</Layout>
