---
import { Picture } from "astro:assets"
import Layout from "../layouts/Layout.astro";

// 1. URL limpia y completa con _embed para la imagen
const wpApiUrl = 'http://localhost/coffeeshop/wordpress/wp-json/wp/v2';
const response = await fetch(`${wpApiUrl}/pages?slug=nosotros&_embed`);
const pages = await response.json();
const page = pages[0];

if (!page) {
  throw new Error("No se encontró la página 'nosotros'");
}

// 2. Extracción limpia de la imagen destacada
const featuredMedia = page._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = featuredMedia?.source_url || featuredMedia?.guid?.rendered || null;
const imageAlt = featuredMedia?.alt_text || page.title.rendered;

// 3. Extracción segura de ACF (por si no viene en la API o está vacío)
const subtitulo = page.acf?.subtitle || "Bienvenidos a nuestra cafetería"; 
---

<Layout 
  title={page.title.rendered}
  subtitle={subtitulo}
  bgImage={imageUrl} 
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
    
    {imageUrl && (
      <Picture 
        src={imageUrl} 
        alt={imageAlt}
        width={800} 
        height={600} 
        formats={['avif', 'webp']} 
        class="rounded-lg shadow-md max-w-full h-auto object-cover"
      />
    )}
    
    <div class="text-xl space-y-3 mt-10 lg:mt-0" set:html={page.content.rendered}></div>
  </div>
</Layout>